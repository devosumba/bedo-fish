# ─── Environment variables ────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values before running locally.
# On Vercel, add each variable under Settings > Environment Variables.

# ─── WhatsApp (Baileys) ───────────────────────────────────────────────────────
# Requires a persistent server (Railway, Render, VPS). Does not work on Vercel
# serverless — email fallback handles notifications on Vercel automatically.
WHATSAPP_RECIPIENT=
WHATSAPP_SESSION_PATH=

# ─── Email (Nodemailer / Gmail SMTP) ─────────────────────────────────────────
# Use a Gmail account with an App Password (not your regular Gmail password).
# Generate an App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Google Maps (optional) ───────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── CallMeBot (optional WhatsApp HTTP fallback) ─────────────────────────────
CALLMEBOT_API_KEY=
